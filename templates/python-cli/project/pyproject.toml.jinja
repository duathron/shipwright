[build-system]
requires = ["setuptools>=68.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ pypi_name }}"
version = "0.0.0"
description = "{{ description }}"
readme = "README.md"
license = "MIT"
requires-python = ">={{ python_version }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
dependencies = [
    "typer>=0.12.0",
    "rich>=13.7.0",
    "pydantic>=2.7.0",
    "shipwright-kit @ git+https://github.com/duathron/shipwright@main",  # security pack ships with base (entry-point, no extra)
]

[tool.shipwright]
preset = "{{ preset }}"

[project.scripts]
{{ cli_command }} = "{{ package_name }}.main:main"

[dependency-groups]
dev = ["pytest>=8.0", "ruff>=0.8", "pre-commit>=4.0", "hypothesis>=6.0"]

[tool.setuptools.packages.find]
include = ["{{ package_name }}*"]

[tool.ruff]
extend = "tooling/ruff-base.toml"

[tool.pytest.ini_options]
testpaths = ["tests"]
